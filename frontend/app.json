{
  "expo": {
    "name": "StayWake",
    "slug": "staywake",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "staywake",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Scan a QR code across the room to stop your alarm",
        "NSMotionUsageDescription": "Count your steps to prove you're up and out of bed"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#000"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "CAMERA",
        "ACTIVITY_RECOGNITION",
        "VIBRATE",
        "WAKE_LOCK",
        "RECEIVE_BOOT_COMPLETED",
        "SCHEDULE_EXACT_ALARM",
        "USE_FULL_SCREEN_INTENT",
        "POST_NOTIFICATIONS",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.CAMERA"
      ],
      "package": "com.antics242.staywake"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-image.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#000"
        }
      ],
      "expo-font",
      "expo-audio",
      [
        "expo-camera",
        {
          "cameraPermission": "Scan a QR code across the room to stop your alarm"
        }
      ],
      [
        "expo-sensors",
        {
          "motionPermission": "Count your steps to prove you're up and out of bed"
        }
      ],
      [
        "expo-notifications",
        {
          "sounds": [
            "./assets/sounds/classic.mp3",
            "./assets/sounds/morning.mp3",
            "./assets/sounds/digital.mp3",
            "./assets/sounds/rooster.mp3",
            "./assets/sounds/siren.mp3",
            "./assets/sounds/critical.mp3"
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "eddda388-b062-479c-90ba-79d8890c1d03"
      }
    }
  }
}
